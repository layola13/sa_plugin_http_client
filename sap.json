{
  "schema": "sa.plugin/1",
  "name": "http-client",
  "version": "0.1.0",
  "source": {
    "type": "local",
    "path": "."
  },
  "abi": {
    "plugin": 1,
    "saasm": ">=0.4.0"
  },
  "artifacts": {
    "linux-x86_64": {
      "path": "zig-out/lib/libhttp-client.so"
    }
  },
  "interfaces": {
    "sai": { "path": "sa_http_client.sai" }
  },
  "skills": ["http.client"],
  "permissions": {
    "fs": [
      { "op": "read", "path": "$PROJECT/**" },
      { "op": "metadata", "path": "$PROJECT/**" },
      { "op": "read", "path": "/etc/**" },
      { "op": "metadata", "path": "/etc/**" },
      { "op": "metadata", "path": "$SA_PLUGINS_HOME/**" }
    ],
    "net": [
      { "url": "https://*", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://localhost", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] },
      { "url": "http://127.0.0.1", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"] }
    ],
    "env": ["HOME", "TMPDIR", "TMP", "TEMP", "SSL_CERT_FILE", "SSL_CERT_DIR", "HTTP_PROXY", "HTTPS_PROXY", "NO_PROXY", "http_proxy", "https_proxy", "no_proxy", "SA_*"],
    "process": { "spawn": false, "exec": [] }
  },
  "dependencies": {
    "node": {
      "version": ">=0.1.0",
      "abi": 1,
      "path": "../sa_plugin_node"
    }
  }
}
